# GoHighLevel private integration
GHL_API_KEY=
GHL_LOCATION_ID=
GHL_PIPELINE_ID=

# Shared dashboard login
DASHBOARD_PASSWORD=
SESSION_SECRET=

# Upstash Redis via Vercel marketplace integration (aggregate result cache)
# -- auto-populated by `vercel env pull` / vercel link, not set by hand
KV_REST_API_URL=
KV_REST_API_TOKEN=

# Phase 2 — Supabase (pipeline history + customer journey)
SUPABASE_URL=
SUPABASE_SECRET_KEY=
GHL_WEBHOOK_SECRET=

# Vercel Cron auth for /api/cron/keep-alive (Vercel sends this automatically
# as `Authorization: Bearer $CRON_SECRET` once this env var exists)
CRON_SECRET=
